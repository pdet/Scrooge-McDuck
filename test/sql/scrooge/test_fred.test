# name: test/sql/scrooge/test_fred.test
# description: Test FRED Economic Data Scanner
# group: [scrooge]

require scrooge

# Test that the function exists and rejects empty series_id
statement error
select * FROM fred_series('', 'test_key')
----
series_id cannot be empty

# Test that the function rejects empty api_key
statement error
select * FROM fred_series('GDP', '')
----
api_key cannot be empty

# Test the 4-argument overload exists (will fail on API call, but proves registration)
statement error
select * FROM fred_series('GDP', 'invalid_key', '2024-01-01'::DATE, '2024-06-01'::DATE)
----
