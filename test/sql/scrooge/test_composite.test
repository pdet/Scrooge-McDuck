# name: test/sql/scrooge/test_composite.test
# description: Test composite_score function
# group: [scrooge]

require scrooge

# All indicators neutral → score near 0
query I
SELECT round(composite_score(50.0, 0.0, 0.5, 0.0), 1);
----
0.0

# Strong bullish: low RSI (oversold), positive MACD, low BB%, positive OBV
query I
SELECT composite_score(25.0, 2.0, 0.1, 0.5) > 0;
----
true

# Strong bearish: high RSI (overbought), negative MACD, high BB%, negative OBV
query I
SELECT composite_score(75.0, -2.0, 0.9, -0.5) < 0;
----
true

# Score bounded — extreme inputs
query I
SELECT composite_score(0.0, 100.0, 0.0, 100.0) <= 100 AND composite_score(0.0, 100.0, 0.0, 100.0) >= -100;
----
true

# NULL input → NULL
query I
SELECT composite_score(NULL, 0.0, 0.5, 0.0);
----
NULL
