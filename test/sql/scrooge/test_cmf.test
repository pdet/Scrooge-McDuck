# name: test/sql/scrooge/test_cmf.test
# description: Test Chaikin Money Flow (CMF) and AD Line functions
# group: [scrooge]

require scrooge

# CMF — all closes at high → MFM=1 → CMF=1
query I
SELECT round(cmf(high, low, close, volume, ts, 3), 2) FROM (VALUES
    ('2024-01-01'::TIMESTAMPTZ, 12.0, 10.0, 12.0, 1000.0),
    ('2024-01-02'::TIMESTAMPTZ, 14.0, 11.0, 14.0, 1200.0),
    ('2024-01-03'::TIMESTAMPTZ, 15.0, 12.0, 15.0, 900.0)
) AS t(ts, high, low, close, volume);
----
1.0

# CMF — all closes at low → MFM=-1 → CMF=-1
query I
SELECT round(cmf(high, low, close, volume, ts, 3), 2) FROM (VALUES
    ('2024-01-01'::TIMESTAMPTZ, 12.0, 10.0, 10.0, 1000.0),
    ('2024-01-02'::TIMESTAMPTZ, 14.0, 11.0, 11.0, 1200.0),
    ('2024-01-03'::TIMESTAMPTZ, 15.0, 12.0, 12.0, 900.0)
) AS t(ts, high, low, close, volume);
----
-1.0

# CMF is between -1 and 1
query I
SELECT cmf(high, low, close, volume, ts) BETWEEN -1.0 AND 1.0 FROM (VALUES
    ('2024-01-01'::TIMESTAMPTZ, 48.70, 47.79, 48.16, 1000.0),
    ('2024-01-02'::TIMESTAMPTZ, 48.72, 48.14, 48.61, 1500.0),
    ('2024-01-03'::TIMESTAMPTZ, 48.90, 48.39, 48.75, 800.0),
    ('2024-01-04'::TIMESTAMPTZ, 48.87, 48.37, 48.63, 1200.0)
) AS t(ts, high, low, close, volume);
----
true

# AD Line — accumulates money flow volume
query I
SELECT round(ad_line(high, low, close, volume, ts), 2) FROM (VALUES
    ('2024-01-01'::TIMESTAMPTZ, 12.0, 10.0, 12.0, 1000.0),
    ('2024-01-02'::TIMESTAMPTZ, 14.0, 11.0, 14.0, 1200.0)
) AS t(ts, high, low, close, volume);
----
2200.0

# AD Line — mixed: first bar MFM=1 (+1000), second bar MFM=-1 (-1200) = -200
query I
SELECT round(ad_line(high, low, close, volume, ts), 2) FROM (VALUES
    ('2024-01-01'::TIMESTAMPTZ, 12.0, 10.0, 12.0, 1000.0),
    ('2024-01-02'::TIMESTAMPTZ, 14.0, 11.0, 11.0, 1200.0)
) AS t(ts, high, low, close, volume);
----
-200.0

# Empty → NULL
query I
SELECT cmf(high, low, close, volume, ts) FROM (VALUES
    ('2024-01-01'::TIMESTAMPTZ, 10.0, 9.0, 9.5, 100.0)
) AS t(ts, high, low, close, volume) WHERE 1=0;
----
NULL
