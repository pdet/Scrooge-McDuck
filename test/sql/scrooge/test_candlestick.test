# name: test/sql/scrooge/test_candlestick.test
# description: Test candlestick pattern recognition functions
# group: [scrooge]

require scrooge

# is_doji — body < 5% of range (4-arg: open, high, low, close)
# range=10, body=0.4 → 4% → TRUE
query I
SELECT is_doji(100.0, 110.0, 100.0, 100.4);
----
true

# range=10, body=1 → 10% → FALSE
query I
SELECT is_doji(100.0, 110.0, 100.0, 101.0);
----
false

# is_doji with threshold (5-arg: open, high, low, close, threshold)
# range=10, body=0.9 → 9%, threshold=10% → TRUE
query I
SELECT is_doji(100.0, 110.0, 100.0, 100.9, 0.10);
----
true

# is_hammer(open, high, low, close)
# open=109.5, high=109.5, low=100, close=109.3
# body=0.2, range=9.5, lower_shadow=9.3, upper_shadow=0
query I
SELECT is_hammer(109.5, 109.5, 100.0, 109.3);
----
true

# Not a hammer — big body
query I
SELECT is_hammer(100.0, 110.0, 100.0, 108.0);
----
false

# is_engulfing(open1, close1, open2, close2)
# prev: open=102, close=100 (bearish)
# curr: open=99, close=103 (bullish, engulfs)
query I
SELECT is_engulfing(102.0, 100.0, 99.0, 103.0);
----
true

# Not engulfing — same size
query I
SELECT is_engulfing(102.0, 100.0, 100.0, 102.0);
----
false
