# name: test/sql/scrooge/test_rsi.test
# description: Test RSI (Relative Strength Index) function
# group: [scrooge]

require scrooge

# Create test data — 20 daily prices with known up/down moves
statement ok
CREATE TABLE rsi_data AS SELECT * FROM (VALUES
    ('2024-01-01'::TIMESTAMPTZ, 44.0),
    ('2024-01-02'::TIMESTAMPTZ, 44.34),
    ('2024-01-03'::TIMESTAMPTZ, 44.09),
    ('2024-01-04'::TIMESTAMPTZ, 43.61),
    ('2024-01-05'::TIMESTAMPTZ, 44.33),
    ('2024-01-06'::TIMESTAMPTZ, 44.83),
    ('2024-01-07'::TIMESTAMPTZ, 45.10),
    ('2024-01-08'::TIMESTAMPTZ, 45.42),
    ('2024-01-09'::TIMESTAMPTZ, 45.84),
    ('2024-01-10'::TIMESTAMPTZ, 46.08),
    ('2024-01-11'::TIMESTAMPTZ, 45.89),
    ('2024-01-12'::TIMESTAMPTZ, 46.03),
    ('2024-01-13'::TIMESTAMPTZ, 45.61),
    ('2024-01-14'::TIMESTAMPTZ, 46.28),
    ('2024-01-15'::TIMESTAMPTZ, 46.28),
    ('2024-01-16'::TIMESTAMPTZ, 46.00),
    ('2024-01-17'::TIMESTAMPTZ, 46.03),
    ('2024-01-18'::TIMESTAMPTZ, 46.41),
    ('2024-01-19'::TIMESTAMPTZ, 46.22),
    ('2024-01-20'::TIMESTAMPTZ, 45.64)
) AS t(ts, price);

# RSI with default period (14) — should return a value between 0 and 100
query I
SELECT round(rsi(price, ts), 2) FROM rsi_data;
----
60.14

# RSI with explicit period
query I
SELECT round(rsi(price, ts, 14), 2) FROM rsi_data;
----
60.14

# RSI with short period
query I
SELECT round(rsi(price, ts, 5), 2) FROM rsi_data;
----
38.64

# All prices going up — RSI should be 100
statement ok
CREATE TABLE up_data AS SELECT * FROM (VALUES
    ('2024-01-01'::TIMESTAMPTZ, 10.0),
    ('2024-01-02'::TIMESTAMPTZ, 11.0),
    ('2024-01-03'::TIMESTAMPTZ, 12.0),
    ('2024-01-04'::TIMESTAMPTZ, 13.0),
    ('2024-01-05'::TIMESTAMPTZ, 14.0),
    ('2024-01-06'::TIMESTAMPTZ, 15.0)
) AS t(ts, price);

query I
SELECT round(rsi(price, ts, 3), 2) FROM up_data;
----
100.0

# Insufficient data for period — should return NULL
query I
SELECT rsi(price, ts, 14) FROM up_data;
----
NULL

# Empty input
query I
SELECT rsi(price, ts) FROM rsi_data WHERE 1=0;
----
NULL
