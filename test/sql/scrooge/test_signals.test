# name: test/sql/scrooge/test_signals.test
# description: Test signal generation functions
# group: [scrooge]

require scrooge

# ─── ma_crossover_signal ──────────────────────────────────

query I
SELECT ma_crossover_signal(50.0, 45.0);
----
BUY

query I
SELECT ma_crossover_signal(45.0, 50.0);
----
SELL

query I
SELECT ma_crossover_signal(50.0, 50.0);
----
HOLD

# ─── rsi_signal (defaults: 70/30) ─────────────────────────

query I
SELECT rsi_signal(75.0);
----
SELL

query I
SELECT rsi_signal(25.0);
----
BUY

query I
SELECT rsi_signal(50.0);
----
HOLD

# ─── rsi_signal (custom thresholds) ──────────────────────

query I
SELECT rsi_signal(65.0, 60.0, 40.0);
----
SELL

query I
SELECT rsi_signal(35.0, 60.0, 40.0);
----
BUY

query I
SELECT rsi_signal(50.0, 60.0, 40.0);
----
HOLD

# ─── bollinger_signal ────────────────────────────────────

query I
SELECT bollinger_signal(105.0, 100.0, 90.0);
----
SELL

query I
SELECT bollinger_signal(85.0, 100.0, 90.0);
----
BUY

query I
SELECT bollinger_signal(95.0, 100.0, 90.0);
----
HOLD

# ─── kelly_fraction ──────────────────────────────────────

# 60% win rate, avg win $2, avg loss $1 → Kelly = (0.6*2 - 0.4)/2 = 0.4
query I
SELECT round(kelly_fraction(0.6, 2.0, 1.0), 2);
----
0.4

# 50% win rate, even payoff → Kelly = 0
query I
SELECT round(kelly_fraction(0.5, 1.0, 1.0), 2);
----
0.0

# 30% win rate → negative Kelly → clamped to 0
query I
SELECT round(kelly_fraction(0.3, 1.0, 1.0), 2);
----
0.0

# High edge → clamped to 1.0
query I
SELECT round(kelly_fraction(0.99, 10.0, 0.1), 2);
----
1.0
