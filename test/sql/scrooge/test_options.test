# name: test/sql/scrooge/test_options.test
# description: Test Black-Scholes option pricing and Greeks
# group: [scrooge]

require scrooge

# bs_call: ATM call (S=K=100, T=1yr, r=5%, vol=20%) ≈ 10.45
query I
SELECT round(bs_call(100, 100, 1.0, 0.05, 0.20), 1);
----
10.5

# bs_put: ATM put should be less than call (put-call parity)
query I
SELECT bs_put(100, 100, 1.0, 0.05, 0.20) < bs_call(100, 100, 1.0, 0.05, 0.20);
----
true

# Put-call parity: C - P = S - K*exp(-rT)
query I
SELECT round(bs_call(100, 100, 1.0, 0.05, 0.20) - bs_put(100, 100, 1.0, 0.05, 0.20) - (100 - 100 * exp(-0.05)), 4);
----
0.0

# bs_delta_call: ATM ≈ 0.5-0.6
query I
SELECT bs_delta_call(100, 100, 1.0, 0.05, 0.20) BETWEEN 0.5 AND 0.7;
----
true

# bs_delta_put: negative
query I
SELECT bs_delta_put(100, 100, 1.0, 0.05, 0.20) < 0;
----
true

# bs_gamma: positive
query I
SELECT bs_gamma(100, 100, 1.0, 0.05, 0.20) > 0;
----
true

# bs_vega: positive
query I
SELECT bs_vega(100, 100, 1.0, 0.05, 0.20) > 0;
----
true

# bs_theta_call: negative (time decay)
query I
SELECT bs_theta_call(100, 100, 1.0, 0.05, 0.20) < 0;
----
true

# bs_implied_vol: recover known vol
query I
SELECT round(bs_implied_vol(bs_call(100, 100, 1.0, 0.05, 0.20), 100, 100, 1.0, 0.05, true), 2);
----
0.2
