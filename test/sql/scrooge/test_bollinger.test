# name: test/sql/scrooge/test_bollinger.test
# description: Test Bollinger Bands functions
# group: [scrooge]

require scrooge

statement ok
CREATE TABLE prices AS SELECT * FROM (VALUES
    ('2024-01-01'::TIMESTAMPTZ, 100.0),
    ('2024-01-02'::TIMESTAMPTZ, 102.0),
    ('2024-01-03'::TIMESTAMPTZ, 98.0),
    ('2024-01-04'::TIMESTAMPTZ, 103.0),
    ('2024-01-05'::TIMESTAMPTZ, 105.0),
    ('2024-01-06'::TIMESTAMPTZ, 101.0),
    ('2024-01-07'::TIMESTAMPTZ, 104.0),
    ('2024-01-08'::TIMESTAMPTZ, 106.0),
    ('2024-01-09'::TIMESTAMPTZ, 99.0),
    ('2024-01-10'::TIMESTAMPTZ, 107.0)
) AS t(ts, price);

# Middle band = SMA — should equal average of last N values
query I
SELECT round(bollinger_middle(price, ts, 5), 2) FROM prices;
----
103.4

# Upper band > middle band
query I
SELECT bollinger_upper(price, ts, 5) > bollinger_middle(price, ts, 5) FROM prices;
----
true

# Lower band < middle band
query I
SELECT bollinger_lower(price, ts, 5) < bollinger_middle(price, ts, 5) FROM prices;
----
true

# Width should be positive
query I
SELECT bollinger_width(price, ts, 5) > 0 FROM prices;
----
true

# Custom std deviation multiplier
query I
SELECT bollinger_upper(price, ts, 5, 1.0) < bollinger_upper(price, ts, 5, 3.0) FROM prices;
----
true

# Empty input
query I
SELECT bollinger_upper(price, ts) FROM prices WHERE 1=0;
----
NULL
